{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "goal-template.schema.json",
  "title": "Goal Template",
  "description": "Schema for Clipper goal templates used to bootstrap companies with pre-built goals.",
  "type": "object",
  "required": ["title", "description"],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Short title for the goal."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "Full description of the goal, supports markdown."
    },
    "milestones": {
      "type": "array",
      "description": "Ordered list of milestones toward achieving the goal.",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Unique identifier for this milestone, referenced by issues."
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "description": "Short title for the milestone."
          },
          "description": {
            "type": "string",
            "description": "Details about what this milestone covers."
          },
          "completionCriteria": {
            "type": "string",
            "description": "How to determine when this milestone is complete."
          }
        }
      }
    },
    "issues": {
      "type": "array",
      "description": "Initial issues to create when bootstrapping this goal.",
      "items": {
        "type": "object",
        "required": ["title"],
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "description": "Issue title."
          },
          "description": {
            "type": "string",
            "description": "Issue description, supports markdown."
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"],
            "default": "medium",
            "description": "Issue priority level."
          },
          "milestone": {
            "type": "string",
            "description": "ID of the milestone this issue belongs to."
          },
          "assignTo": {
            "type": "string",
            "description": "Role name or 'capability:<skill>' to resolve at assembly time."
          }
        }
      }
    }
  }
}
